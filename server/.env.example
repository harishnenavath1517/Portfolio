# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/portfolio?retryWrites=true&w=majority

# Anthropic API key (server-side only — never expose to the browser)
ANTHROPIC_API_KEY=sk-ant-...

# Allowed frontend origin for CORS (set to your Vercel URL in production)
CLIENT_ORIGIN=http://localhost:5173

# Server port (Render sets this automatically)
PORT=5000
