{
  "name": "portfolio-server",
  "version": "1.0.0",
  "description": "MERN portfolio backend — Express + MongoDB + Anthropic",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch index.ts",
    "build": "esbuild index.ts --bundle --platform=node --packages=external --format=esm --outfile=dist/index.js",
    "start": "node dist/index.js",
    "seed": "tsx seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "mongoose": "^8.9.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.1",
    "typescript": "^5.7.0"
  }
}
